{
  "name": "building-serverless",
  "version": "0.1.0",
  "bin": {
    "infra": "bin/building-serverless.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "utils:convertCDKtoCfn": "node ./scripts/convert-template.mjs",
    "infra:destroy": "npm run cdk destroy -- BuildingServerlessAPIs",
    "infra:deploy": "npm run cdk deploy -- BuildingServerlessAPIs",
    "infra:deploy:hotswap": "npm run cdk deploy -- --hotswap-fallback BuildingServerlessAPIs",
    "infra:synth": "npm run cdk synth -- BuildingServerlessAPIs",
    "infra:wsPrep": "rimraf ./Workshop && npm run utils:convertCDKtoCfn -- BuildingServerlessAPIs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts}": "biome check --write",
    "*.md": "markdownlint-cli2 --fix"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.1060.0",
    "@biomejs/biome": "^2.4.6",
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "25.5.2",
    "aws-cdk": "2.1126.0",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "rimraf": "^6.1.3",
    "shelljs": "^0.10.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.257.0",
    "cdk-nag": "^2.38.2",
    "constructs": "^10.6.0",
    "source-map-support": "^0.5.21"
  }
}
